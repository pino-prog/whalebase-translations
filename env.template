# Figma Personal Access Token
# 발급 방법: Figma → Account Settings → Personal access tokens
FIGMA_TOKEN=your_figma_personal_access_token

# Figma File ID
# Figma URL에서 추출: https://www.figma.com/file/FILE_ID/...
FIGMA_FILE_ID=your_figma_file_id

# Anthropic API Key (번역용)
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=your_anthropic_api_key

# (선택) 번역할 언어 코드 (쉼표 구분)
# 미설정 시 기본값: ko,zh,ja
# 지원 언어:
#   ko  - Korean (한국어)
#   zh  - Chinese Simplified (简体中文)
#   ja  - Japanese (日本語)
#   id  - Indonesian (Bahasa Indonesia)
#   hi  - Hindi (हिन्दी)
#   tr  - Turkish (Türkçe)
#   vi  - Vietnamese (Tiếng Việt)
#   pt  - Portuguese Brazilian (Português do Brasil)
#   ru  - Russian (Русский)
#   de  - German (Deutsch)
#   es  - Spanish (Español)
#   fr  - French (Français)
TARGET_LANGS=ko,zh,ja

# (선택) 특정 Figma 페이지만 추출하려면 설정
# 비워두면 모든 페이지를 추출
FIGMA_PAGE_NAME=

# (선택) 어드민 페이지 비밀번호 — npm run share 사용 시 필수
# 외부에 공유할 때 이 비밀번호를 알아야 접속 가능
ADMIN_PASSWORD=
